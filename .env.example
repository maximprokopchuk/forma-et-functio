# --- Database (PostgreSQL via Neon or local Docker) ---
DATABASE_URL=
DIRECT_DATABASE_URL=

# --- Auth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI (OpenRouter gateway) ---
OPENROUTER_API_KEY=

# Hard daily cap for AI spend across all users, in USD
AI_MAX_DAILY_USD=10

# --- Vercel Cron ---
# Shared secret checked by /api/cron/retry-submissions (x-cron-secret header).
# Generate with: openssl rand -base64 32
CRON_SECRET=

# --- Canonical site URL ---
# Used by sitemap.xml, robots.txt, and metadataBase for OG image URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics (optional) ---
# If set, loads plausible.io/js/script.js on every page.
# Leave blank to disable Plausible entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
